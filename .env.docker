# ─────────────────────────────────────────────────────────────────────────────
# Aegis Docker Compose environment — placeholders only.
# Copy to .env.docker.local (gitignored) and fill in real values.
# This file is committed with placeholder values. Never put real secrets here.
# ─────────────────────────────────────────────────────────────────────────────

# ── Casper network ──────────────────────────────────────────────────────────
CASPER_NETWORK=casper-test
CASPER_NODE_RPC_URL=https://node.testnet.cspr.cloud/rpc
CSPR_CLOUD_API_URL=https://api.testnet.cspr.cloud
CSPR_CLOUD_API_KEY=replace-with-your-cspr-cloud-key

# ── Deployed contract hashes (populated after deploy:testnet) ────────────────
# Leave blank for mock/demo mode — chain reads return mock state.
VAULT_CONTRACT_HASH=
REGISTRY_CONTRACT_HASH=

# ── Agent signing (TESTNET ONLY) ─────────────────────────────────────────────
# Leave blank for mock-sign demo mode.
AGENT_PRIVATE_KEY_HEX=
AGENT_ACCOUNT_HASH=demo-agent-account-hash-placeholder

# ── LLM ─────────────────────────────────────────────────────────────────────
# Leave blank to use MockLlmClient (loop runs but decisions are synthesized).
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=replace-with-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Oracle ───────────────────────────────────────────────────────────────────
ORACLE_PORT=4021
# In compose, agent reaches oracle via service name; the value below is for
# agent→oracle within the compose network. The dashboard CSP uses the
# NEXT_PUBLIC_ORACLE_URL env which is set per-service in docker-compose.yml.
ORACLE_URL=http://oracle:4021
ORACLE_PRICE_MOTES=1000000
X402_FACILITATOR=mock
X402_FACILITATOR_URL=

# ── Agent loop ───────────────────────────────────────────────────────────────
AGENT_LOOP_INTERVAL_MS=30000
REALLOCATION_DRIFT_BPS=50
MIN_CONFIDENCE_THRESHOLD=60
MIN_VAULT_BALANCE_MOTES=100000000000
MAX_ASSET_WEIGHT_BPS=6000
TX_CONFIRM_TIMEOUT_MS=60000
REPUTATION_UPDATE_EPOCHS=3
REPUTATION_SEED_SCORE=50

# ── Dashboard public vars ────────────────────────────────────────────────────
NEXT_PUBLIC_ORACLE_URL=http://localhost:4021
NEXT_PUBLIC_CSPR_CLOUD_API_URL=https://api.testnet.cspr.cloud
NEXT_PUBLIC_VAULT_CONTRACT_HASH=
NEXT_PUBLIC_CASPER_NETWORK=casper-test
NEXT_PUBLIC_CASPER_EXPLORER_TX_BASE=https://testnet.cspr.live/deploy
NEXT_PUBLIC_USE_MOCK_WALLET=true

# ── Deploy guard ─────────────────────────────────────────────────────────────
# Never set this to true in this file — it must be set explicitly in the shell.
ALLOW_TESTNET_DEPLOY=false
