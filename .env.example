# ─────────────────────────────────────────────────────────────────────────────
# Aegis environment — copy to .env and fill in. NEVER commit a real .env.
# All values below are placeholders. No real keys/secrets in this file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Casper network ──────────────────────────────────────────────────────────
CASPER_NETWORK=casper-test
CASPER_NODE_RPC_URL=https://node.testnet.cspr.cloud/rpc
CSPR_CLOUD_API_URL=https://api.testnet.cspr.cloud
CSPR_CLOUD_API_KEY=replace-with-your-cspr-cloud-key
CASPER_EXPLORER_TX_BASE=https://testnet.cspr.live/deploy

# ── Deployed contract hashes (populated by deploy:testnet) ───────────────────
VAULT_CONTRACT_HASH=
REGISTRY_CONTRACT_HASH=

# ── Agent signing (TESTNET ONLY — never a mainnet key / seed phrase) ─────────
# Hex-encoded ed25519/secp256k1 secret key for the agent's testnet account.
# This same account is the contract owner in the demo (see ASSUMPTIONS A-016).
AGENT_PRIVATE_KEY_HEX=replace-with-testnet-secret-key-hex
AGENT_ACCOUNT_HASH=
AGENT_KEY_ALGORITHM=ed25519

# ── LLM (provider-agnostic; pick one) ────────────────────────────────────────
LLM_PROVIDER=anthropic            # anthropic | openai
ANTHROPIC_API_KEY=replace-with-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── x402 oracle ──────────────────────────────────────────────────────────────
ORACLE_PORT=4021
ORACLE_URL=http://localhost:4021
ORACLE_PRICE_MOTES=1000000        # 0.001 CSPR per call
X402_FACILITATOR=mock             # mock | live
X402_FACILITATOR_URL=

# ── Self-contained local demo (no keys, no chain, no quota) ──────────────────
# When true the agent runs the FULL perceive→decide→act cycle offline:
# seeded placeholder chain reads, a deterministic mock LLM, and an in-memory
# MOCK tx client that returns `mock-…` hashes (NEVER submits on-chain).
# Lets a reviewer run `pnpm oracle && pnpm agent && pnpm dev` with zero keys.
AGENT_OFFLINE_DEMO=false

# ── Agent loop tuning ────────────────────────────────────────────────────────
AGENT_LOOP_INTERVAL_MS=30000
REALLOCATION_DRIFT_BPS=200        # demo override: 50
MIN_CONFIDENCE_THRESHOLD=60
MIN_VAULT_BALANCE_MOTES=0           # local demo: 0 = agent runs on empty vault; use 100000000000 for production-like guard
MAX_ASSET_WEIGHT_BPS=6000
TX_CONFIRM_TIMEOUT_MS=60000
REPUTATION_UPDATE_EPOCHS=3
REPUTATION_SEED_SCORE=50

# ── Deploy guard (must be true to run deploy:testnet) ────────────────────────
ALLOW_TESTNET_DEPLOY=false
