# Aegis Dashboard — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.

# Public vars (safe to expose in client bundle — not secrets)
NEXT_PUBLIC_CSPR_CLOUD_API_URL=https://api.testnet.cspr.cloud
NEXT_PUBLIC_ORACLE_URL=http://localhost:4021
NEXT_PUBLIC_CASPER_EXPLORER_TX_BASE=https://testnet.cspr.live/deploy
NEXT_PUBLIC_VAULT_CONTRACT_HASH=

# Server-only vars (never prefixed NEXT_PUBLIC_)
CSPR_CLOUD_API_URL=https://api.testnet.cspr.cloud
CSPR_CLOUD_API_KEY=replace-with-your-cspr-cloud-key
VAULT_CONTRACT_HASH=
REGISTRY_CONTRACT_HASH=
AGENT_ACCOUNT_HASH=

# Agent trigger endpoint (the @aegis/agent process exposes this)
AGENT_TRIGGER_URL=http://localhost:4022/trigger
