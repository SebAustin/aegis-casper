{
  "name": "@aegis/mcp-server",
  "version": "0.1.0",
  "description": "MCP 2025-11-25 server for Aegis — 6 tools + 4 resources over stdio",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "aegis-mcp": "./dist/server.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@aegis/agent": "workspace:*",
    "@aegis/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
